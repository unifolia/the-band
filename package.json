{
  "name": "the-band",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && vite",
    "build:wasm": "wasm-pack build rust/band_engine --target web --out-dir ../../src/wasm/band_engine",
    "build": "npm run build:wasm && vite build",
    "test:rust": "cargo test --manifest-path rust/band_engine/Cargo.toml",
    "test": "npm run test:rust"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "vite": "^8.0.14",
    "wasm-pack": "^0.15.0"
  }
}
